{
    "name": "@lucky/shared",
    "version": "2.16.0",
    "description": "Shared code for Lucky modular monolith",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./config": {
            "types": "./dist/config/index.d.ts",
            "default": "./dist/config/index.js"
        },
        "./services": {
            "types": "./dist/services/index.d.ts",
            "default": "./dist/services/index.js"
        },
        "./services/guildAutomation": {
            "types": "./dist/services/guildAutomation/index.d.ts",
            "default": "./dist/services/guildAutomation/index.js"
        },
        "./services/*": {
            "types": "./dist/services/*.d.ts",
            "default": "./dist/services/*.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "default": "./dist/utils/index.js"
        },
        "./utils/monitoring": {
            "types": "./dist/utils/monitoring/index.d.ts",
            "default": "./dist/utils/monitoring/index.js"
        },
        "./utils/support": {
            "types": "./dist/utils/support/index.d.ts",
            "default": "./dist/utils/support/index.js"
        },
        "./utils/*": {
            "types": "./dist/utils/*.d.ts",
            "default": "./dist/utils/*.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        },
        "./constants": {
            "types": "./dist/constants/index.d.ts",
            "default": "./dist/constants/index.js"
        },
        "./errors": {
            "types": "./dist/errors/index.d.ts",
            "default": "./dist/errors/index.js"
        },
        "./errors/*": {
            "types": "./dist/errors/*.d.ts",
            "default": "./dist/errors/*.js"
        }
    },
    "scripts": {
        "build": "tsc -b --force && node add-js-extensions.js",
        "dev": "tsc --watch",
        "type:check": "tsc --noEmit",
        "test": "jest",
        "test:ci": "jest --ci",
        "docs:check": "node check-docs-coverage.mjs"
    },
    "dependencies": {
        "@prisma/client": "^7.8.0",
        "@sentry/node": "^10.53.1",
        "@vercel/flags-core": "^1.4.0",
        "axios": "^1.16.1",
        "chalk": "^5.6.2",
        "dotenv": "^17.4.2",
        "ioredis": "^5.10.1",
        "uuid": "^14.0.0",
        "zod": "^4.4.3"
    },
    "optionalDependencies": {
        "@infisical/sdk": "^5.0.2"
    },
    "devDependencies": {
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.40",
        "@types/node": "^25.9.1",
        "glob": "^13.0.6",
        "typedoc": "^0.28.19",
        "typedoc-plugin-coverage": "^4.0.3",
        "typescript": "^6.0.3"
    }
}
