{
    "name": "@lucky/shared",
    "version": "2.6.147",
    "description": "Shared code for Lucky modular monolith",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./config": {
            "types": "./dist/config/index.d.ts",
            "default": "./dist/config/index.js"
        },
        "./services": {
            "types": "./dist/services/index.d.ts",
            "default": "./dist/services/index.js"
        },
        "./services/*": {
            "types": "./dist/services/*.d.ts",
            "default": "./dist/services/*.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "default": "./dist/utils/index.js"
        },
        "./utils/*": {
            "types": "./dist/utils/*.d.ts",
            "default": "./dist/utils/*.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        },
        "./constants": {
            "types": "./dist/constants/index.d.ts",
            "default": "./dist/constants/index.js"
        }
    },
    "scripts": {
        "build": "tsc -b --force && node add-js-extensions.js",
        "dev": "tsc --watch",
        "type:check": "tsc --noEmit",
        "test": "jest",
        "test:ci": "jest --ci"
    },
    "dependencies": {
        "@gar/promise-retry": "^1.0.3",
        "@npmcli/agent": "^4.0.0",
        "@npmcli/fs": "^5.0.0",
        "@prisma/client": "^7.6.0",
        "@sentry/node": "^10.47.0",
        "axios": "^1.15.0",
        "chalk": "^5.6.2",
        "dotenv": "^17.4.1",
        "fs-minipass": "^3.0.3",
        "ioredis": "^5.10.1",
        "minipass": "^7.1.3",
        "minipass-collect": "^2.0.1",
        "minipass-fetch": "^5.0.2",
        "minipass-flush": "^2.0.0",
        "minipass-pipeline": "^3.0.0",
        "negotiator": "^1.0.0",
        "proc-log": "^6.1.0",
        "ssri": "^13.0.1",
        "unique-filename": "^5.0.0",
        "unleash-client": "^6.10.1",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "optionalDependencies": {
        "@infisical/sdk": "^5.0.0"
    },
    "devDependencies": {
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.24",
        "@types/node": "^25.6.0",
        "glob": "^13.0.6",
        "typescript": "^6.0.2"
    }
}
