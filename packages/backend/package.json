{
    "name": "@lucky/backend",
    "version": "2.16.0",
    "description": "Express API server for Lucky",
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "build": "tsc && node add-js-extensions.js",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "type:check": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint . -c ../../eslint.config.js",
        "lint:fix": "npm run lint -- --fix",
        "lint:full": "eslint . -c ../../eslint.config.js"
    },
    "dependencies": {
        "@lucky/shared": "file:../shared",
        "connect-redis": "^9.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "express-session": "^1.19.0",
        "multer": "^2.0.1",
        "prom-client": "^15.1.3",
        "session-file-store": "^1.5.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.8",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.9.1",
        "@types/session-file-store": "^1.2.6",
        "@types/supertest": "^7.2.0",
        "jest": "^30.4.2",
        "supertest": "^7.0.0",
        "ts-jest": "^29.4.11",
        "tsup": "^8.5.1",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    }
}
