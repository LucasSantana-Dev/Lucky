{
    "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/core/schema/stryker-core.json",
    "version": "7",
    "testRunner": "jest",
    "jest": {
        "projectType": "custom",
        "configFile": "./jest.mutation.cjs"
    },
    "mutate": [
        "src/services/HeartbeatService.ts",
        "src/services/VoiceChannelStatusService.ts",
        "src/services/WeeklyDigestService.ts",
        "src/services/RssBridgeService.ts",
        "src/utils/general/formatDuration.ts"
    ],
    "reporters": ["html", "clear-text", "progress"],
    "timeoutMS": 15000,
    "timeoutFactor": 1.5,
    "logLevel": "info",
    "concurrency": 2,
    "ignoreStatic": false,
    "inPlace": true,
    "incremental": true,
    "incrementalFile": "reports/stryker-incremental.json",
    "thresholds": {
        "high": 85,
        "low": 45,
        "break": 40
    }
}
