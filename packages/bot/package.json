{
    "name": "@lucky/bot",
    "version": "2.15.0",
    "description": "Discord bot application",
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "preflight": "npm --prefix ../.. run db:generate && npm --prefix ../.. run build:shared",
        "build": "npm run preflight && tsc && node add-js-extensions.js",
        "dev": "tsx watch src/index.ts",
        "sentry:test": "tsx src/scripts/sentryTestCli.ts",
        "sentry:test:dist": "node dist/scripts/sentryTestCli.js",
        "start": "node dist/index.js",
        "type:check": "npm run preflight && tsc --noEmit",
        "test": "jest",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@discord-player/extractor": "^7.2.0",
        "@discordjs/builders": "^1.14.1",
        "@discordjs/opus": "^0.10.0",
        "@lucky/shared": "file:../shared",
        "@sentry/node": "^10.53.1",
        "chalk": "^5.6.2",
        "discord-player": "^7.1.0",
        "discord-player-spotify": "^1.1.9",
        "discord-player-youtubei": "^3.0.0-beta.4",
        "discord.js": "^14.26.4",
        "dotenv": "^17.4.2",
        "ffmpeg-static": "^5.3.0",
        "lru-cache": "^11.5.0",
        "play-dl": "^1.9.7",
        "prom-client": "^15.1.3",
        "ws": "^8.21.0",
        "youtube-dl-exec": "^3.1.7",
        "youtubei.js": "^16.0.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.1",
        "@types/ws": "^8.5.13",
        "jest": "^30.4.2",
        "ts-jest": "^29.4.11",
        "tsup": "^8.5.1",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    }
}
